# Anayasa — environment variables
# Copy to `.env` and fill in:  cp .env.example .env
# .env is gitignored and must NEVER be committed.

# ─── Supabase (required) ───
# Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# ─── Public app config (optional) ───
VITE_APP_NAME=Anayasa
VITE_APP_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────────
# NOTE: There is deliberately NO service-role key here. It must never
# live in the frontend. Edge Functions read it from Supabase's secret
# manager instead:   supabase secrets set SERVICE_ROLE_KEY=...
# ───────────────────────────────────────────────────────────────
